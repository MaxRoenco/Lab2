<!doctype html>
<html lang="{{ site.meta.lang | default('en') }}">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta
      name="description"
      content="{{ description | default(site.meta.description) }}"
    />
    <title>{{ title | default(site.meta.title) }}</title>

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;600;700&family=Inter:wght@300;400;500;600&display=swap"
      rel="stylesheet"
    />

    <script src="https://cdn.tailwindcss.com"></script>

    <link rel="stylesheet" href="/assets/css/reset.css" />
    <link rel="stylesheet" href="/assets/css/style.css" />
  </head>
  <body>
    <nav class="nav" id="nav" aria-label="Main navigation">
      <div class="nav__container">
        <a href="#home" class="nav__logo" aria-label="Kvadrat homepage">
          <span class="nav__logo-square" aria-hidden="true"></span>
          {{ site.brand }}
        </a>

        <ul class="nav__links" id="navLinks" role="list">
          {% for item in site.nav %}
            <li><a href="{{ item.href }}">{{ item.label }}</a></li>
          {% endfor %}
        </ul>

        <a href="{{ site.navCta.href }}" class="btn btn--accent btn--nav"
          >{{ site.navCta.label }}</a
        >

        <button
          class="nav__burger"
          id="navBurger"
          aria-label="Toggle menu"
          aria-expanded="false"
        >
          <span></span>
          <span></span>
          <span></span>
        </button>
      </div>
    </nav>

    <main>
      {{ content | safe }}
    </main>

    <footer class="footer">
      <div class="container">
        <div class="footer__grid">
          <div class="footer__brand">
            <a href="#home" class="nav__logo" aria-label="Kvadrat homepage">
              <span class="nav__logo-square" aria-hidden="true"></span>
              {{ site.brand }}
            </a>
            <p>{{ site.footer.brandDescription }}</p>
          </div>

          <div class="footer__links">
            <h4>Quick Links</h4>
            <ul>
              {% for link in site.footer.quickLinks %}
                <li><a href="{{ link.href }}">{{ link.label }}</a></li>
              {% endfor %}
            </ul>
          </div>

          <div class="footer__links">
            <h4>Courses</h4>
            <ul>
              {% for link in site.footer.coursesLinks %}
                <li><a href="{{ link.href }}">{{ link.label }}</a></li>
              {% endfor %}
            </ul>
          </div>

          <div class="footer__social">
            <h4>Follow Us</h4>
            <div class="footer__social-links">
              {% for social in site.footer.social %}
                <a
                  class="social-link"
                  href="{{ social.href }}"
                  {% if social.href != '#' %}
                    target="_blank" rel="noopener noreferrer"
                  {% endif %}
                  >{{ social.label }}</a
                >
              {% endfor %}
            </div>
          </div>
        </div>

        <div class="footer__bottom">
          <p>{{ site.footer.copyright }}</p>
        </div>
      </div>
    </footer>

    <script src="/assets/js/site.js"></script>
    <script src="https://identity.netlify.com/v1/netlify-identity-widget.js"></script>
  </body>
</html>