---
layout: base.njk
title: Kvadrat - Acting Academy | Chisinau
---
{% set home = collections.home[0].data %}

{% if not home.hide_hero_section %}
<section class="hero" id="home" aria-label="Hero">
  <div class="hero__bg" aria-hidden="true"></div>

  <div class="hero__content">
    <span class="hero__label">{{ home.hero_label }}</span>

    <h1 class="hero__title">{{ home.hero_title | safe }}</h1>

    <p class="hero__subtitle">{{ home.hero_subtitle }}</p>

    <div class="hero__actions">
      <a href="{{ home.hero_primary_href }}" class="btn btn--accent"
        >{{ home.hero_primary_label }}</a
      >
      <a href="{{ home.hero_secondary_href }}" class="btn btn--outline"
        >{{ home.hero_secondary_label }}</a
      >
    </div>
  </div>

  <div class="hero__scroll-hint" aria-hidden="true">
    <span>Scroll</span>
    <div class="hero__scroll-line"></div>
  </div>
</section>
{% endif %}

{% if not home.hide_mobile_spotlight_section %}
<section class="mobile-spotlight" aria-label="Academy highlights">
  <div class="mobile-spotlight__inner mx-auto max-w-[480px] text-center">
    <p class="mobile-spotlight__eyebrow">{{ home.mobile_spotlight_eyebrow }}</p>
    <div class="mobile-spotlight__stats">
      <div class="mobile-spotlight__stat">
        <strong>{{ home.mobile_stat_1_value }}</strong>
        <span>{{ home.mobile_stat_1_label }}</span>
      </div>
      <div class="mobile-spotlight__stat">
        <strong>{{ home.mobile_stat_2_value }}</strong>
        <span>{{ home.mobile_stat_2_label }}</span>
      </div>
      <div class="mobile-spotlight__stat">
        <strong>{{ home.mobile_stat_3_value }}</strong>
        <span>{{ home.mobile_stat_3_label }}</span>
      </div>
    </div>
    <a href="{{ home.mobile_spotlight_cta_href }}" class="btn btn--accent btn--full"
      >{{ home.mobile_spotlight_cta_label }}</a
    >
  </div>
</section>
{% endif %}

{% if not home.hide_about_section %}
<section class="about" id="about" aria-label="About Kvadrat">
  <div class="container">
    <div class="about__grid">
      <div class="about__visual">
        <div class="about__image-frame">
          <img src="{{ home.about_image }}" alt="{{ home.about_image_alt }}" />
        </div>

        <div class="about__stats">
          <div class="about__stat">
            <span class="about__stat-number">{{ home.about_stat_1_value }}</span>
            <span class="about__stat-label">{{ home.about_stat_1_label }}</span>
          </div>
          <div class="about__stat">
            <span class="about__stat-number">{{ home.about_stat_2_value }}</span>
            <span class="about__stat-label">{{ home.about_stat_2_label }}</span>
          </div>
          <div class="about__stat">
            <span class="about__stat-number">{{ home.about_stat_3_value }}</span>
            <span class="about__stat-label">{{ home.about_stat_3_label }}</span>
          </div>
        </div>
      </div>

      <div class="about__text">
        <span class="section-label">{{ home.about_label }}</span>
        <h2 class="section-title">{{ home.about_title | safe }}</h2>
        <p>{{ home.about_text_1 }}</p>
        <p>{{ home.about_text_2 }}</p>
        <a href="{{ home.about_cta_href }}" class="btn btn--accent"
          >{{ home.about_cta_label }}</a
        >
      </div>
    </div>
  </div>
</section>
{% endif %}

{% if not home.hide_programs_section %}
<section class="courses" id="courses" aria-label="Courses">
  <div class="container">
    <div class="section-header">
      <span class="section-label">{{ home.programs_label }}</span>
      <h2 class="section-title">{{ home.programs_title }}</h2>
      <p class="section-subtitle">{{ home.programs_subtitle }}</p>
    </div>

    <div class="courses__grid">
      {% for course in collections.courses %}
        <article class="course-card{% if course.data.featured %} course-card--featured{% endif %}">
          {% if course.data.featured %}
            <span class="course-card__badge">Most Popular</span>
          {% endif %}
          <div class="course-card__icon" aria-hidden="true">{{ course.data.icon | safe }}</div>
          <span class="course-card__level">{{ course.data.level }}</span>
          <h3 class="course-card__title">{{ course.data.title }}</h3>
          <p class="course-card__desc">{{ course.data.description }}</p>
          <ul class="course-card__details">
            <li>Duration: {{ course.data.duration }}</li>
            <li>{{ course.data.sessions }}</li>
            <li>Max {{ course.data.max_students }} students</li>
          </ul>
          <a
            href="#contact"
            class="btn{% if course.data.featured %} btn--accent{% else %} btn--outline{% endif %} btn--sm"
            >Enroll</a
          >
        </article>
      {% endfor %}
    </div>
  </div>
</section>
{% endif %}

{% if not home.hide_gallery_section %}
<section class="gallery" id="gallery" aria-label="Gallery">
  <div class="container">
    <div class="section-header">
      <span class="section-label">{{ home.gallery_label }}</span>
      <h2 class="section-title">{{ home.gallery_title }}</h2>
      <p class="section-subtitle">{{ home.gallery_subtitle }}</p>
    </div>

    <div class="gallery__grid" role="list">
      {% for item in collections.galleryItems %}
        <div class="gallery__item gallery__item--{{ loop.index }}" role="listitem">
          <img src="{{ item.data.image }}" alt="{{ item.data.alt }}" />
          <span>{{ item.data.caption }}</span>
        </div>
      {% endfor %}
    </div>
  </div>
</section>
{% endif %}

{% if not home.hide_testimonials_section %}
<section class="testimonials" id="testimonials" aria-label="Testimonials">
  <div class="container">
    <div class="section-header">
      <span class="section-label">{{ home.testimonials_label }}</span>
      <h2 class="section-title">{{ home.testimonials_title }}</h2>
    </div>

    <div class="testimonials__grid">
      {% for testimonial in collections.testimonials %}
        <article class="testimonial-card{% if testimonial.data.featured %} testimonial-card--featured{% endif %}">
          <div class="testimonial-card__quote" aria-hidden="true">"</div>
          <p class="testimonial-card__text">{{ testimonial.data.quote }}</p>
          <div class="testimonial-card__author">
            <div class="testimonial-card__avatar" aria-hidden="true">
              {{ testimonial.data.initials }}
            </div>
            <div>
              <strong>{{ testimonial.data.author }}</strong>
              <span>{{ testimonial.data.role }}</span>
            </div>
          </div>
        </article>
      {% endfor %}
    </div>
  </div>
</section>
{% endif %}

{% if not home.hide_contact_section %}
<section class="contact" id="contact" aria-label="Contact">
  <div class="container">
    <div class="contact__grid">
      <div class="contact__info">
        <span class="section-label">{{ home.contact_label }}</span>
        <h2 class="section-title">{{ home.contact_title }}</h2>
        <p>{{ home.contact_text }}</p>

        <ul class="contact__details">
          <li>
            <div class="contact__icon" aria-hidden="true">&#128205;</div>
            <span>{{ home.contact_address }}</span>
          </li>
          <li>
            <div class="contact__icon" aria-hidden="true">&#128222;</div>
            <a href="tel:{{ home.contact_phone_link }}">{{ home.contact_phone }}</a>
          </li>
          <li>
            <div class="contact__icon" aria-hidden="true">&#9993;</div>
            <a href="mailto:{{ home.contact_email }}">{{ home.contact_email }}</a>
          </li>
          <li>
            <div class="contact__icon" aria-hidden="true">&#128337;</div>
            <span>{{ home.contact_hours | replace(" | ", "<br />") | safe }}</span>
          </li>
        </ul>
      </div>

      <form class="contact__form" action="#" method="post" novalidate>
        <div class="form-group">
          <label for="name">Full Name</label>
          <input
            type="text"
            id="name"
            name="name"
            placeholder="Your name"
            required
            autocomplete="name"
          />
        </div>

        <div class="form-group">
          <label for="email">Email Address</label>
          <input
            type="email"
            id="email"
            name="email"
            placeholder="your@email.com"
            required
            autocomplete="email"
          />
        </div>

        <div class="form-group">
          <label for="phone">Phone Number</label>
          <input
            type="tel"
            id="phone"
            name="phone"
            placeholder="+373 xx xxx xxx"
            autocomplete="tel"
          />
        </div>

        <div class="form-group">
          <label for="course">Interested Course</label>
          <select id="course" name="course">
            <option value="">Select a course...</option>
            {% for course in collections.courses %}
              <option value="{{ course.fileSlug }}">{{ course.data.title }}</option>
            {% endfor %}
          </select>
        </div>

        <div class="form-group">
          <label for="message">Message</label>
          <textarea
            id="message"
            name="message"
            rows="4"
            placeholder="Any questions or additional info..."
          ></textarea>
        </div>

        <button type="submit" class="btn btn--accent btn--full">Send Message</button>
      </form>
    </div>
  </div>
</section>
{% endif %}

{% if not home.hide_mascot %}
