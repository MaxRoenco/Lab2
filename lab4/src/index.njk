  </div>
</div>
{% endif %}

{% if not home.hide_mobile_cta_bar %}
<div class="mobile-cta-bar items-center" aria-label="Enroll call to action" id="mobileCta">
  <span class="mobile-cta-bar__text">{{ home.mobile_cta_text }}</span>
  <a href="{{ home.mobile_cta_href }}" class="btn btn--accent btn--sm"
    >{{ home.mobile_cta_label }}</a
  >
</div>
{% endif %}
